// Prisma schema for @signex/db.
// Datasource + generator ONLY — no domain models yet (ready to `prisma migrate`).
// The generated client is a build artifact: it lands in ../generated/client and is git-ignored.
// Regenerate with `npm run -w @signex/db generate`.

generator client {
  provider      = "prisma-client-js"
  output        = "../generated/client"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// CMS FOUNDATION (spec §4). Conventions:
//   LocalizedText = Json { en, vi } (LocalizedTextSchema in @signex/shared);
//   every Json column is zod-validated before write AND again at publish.
// SNAPSHOT-SERIALIZED  : Category, Product, Asset (as frozen refs), ContentBlock.
// OPERATIONAL-ONLY     : User, Session, AuditLog, Release, PublishedPointer,
//                        WorkingState, FormSubmission, AssetRef, ReleaseAssetRef.
// ID strategy is locked to cuid() so @signex/shared's Id can be z.string().cuid().
// =============================================================================

// ===== IDENTITY / RBAC =====
enum Role {
  EDITOR
  PUBLISHER
  ADMIN
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String // node:crypto scrypt (no native dep)
  role         Role      @default(EDITOR)
  isActive     Boolean   @default(true) // deactivate, never hard-delete (preserves audit FKs)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  sessions                 Session[]
  releasesCreated          Release[]        @relation("ReleaseCreatedBy")
  releasesPublished        Release[]        @relation("ReleasePublishedBy")
  assetsUploaded           Asset[]
  auditLogs                AuditLog[]
  themesCreated            Theme[]          @relation("ThemeCreatedBy")
  catalogReleasesCreated   CatalogRelease[] @relation("CatalogReleaseCreatedBy")
  catalogReleasesPublished CatalogRelease[] @relation("CatalogReleasePublishedBy")
  catalogDraftsUpdated     CatalogDraft[]   @relation("CatalogDraftUpdatedBy")
}

model Session {
  id         String    @id @default(cuid())
  tokenHash  String    @unique // sha256(raw token); raw lives only in the cookie
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  revokedAt  DateTime? // logout / demote / deactivate => instant kill
  lastSeenAt DateTime  @default(now())
  ip         String?
  userAgent  String?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String // "content.update" | "release.publish" | "release.rollback" ...
  entityType String
  entityId   String?
  meta       Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

// ===== MEDIA (R2) =====
enum AssetStatus {
  PENDING
  READY
}

enum AssetKind {
  IMAGE
  VIDEO
  SVG
  DOCUMENT
}

model Asset {
  id           String      @id @default(cuid())
  status       AssetStatus @default(PENDING)
  kind         AssetKind
  sha256       String      @unique // content hash => dedup + immutability
  r2Key        String      @unique // originals/<hash32>/<slug>.<ext> ; URL is DERIVED, never stored
  mime         String
  bytes        BigInt // BigInt to avoid a future migration on large video
  width        Int?
  height       Int?
  duration     Float?
  originalName String
  altDefault   Json? // LocalizedText fallback ONLY; real alt is per-use
  posterId     String? // video poster (an IMAGE asset)
  poster       Asset?      @relation("AssetPoster", fields: [posterId], references: [id])
  postered     Asset[]     @relation("AssetPoster")
  uploadedById String?
  uploadedBy   User?       @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt    DateTime    @default(now())
  deletedAt    DateTime? // soft-delete; service-layer enforces "no delete while referenced"

  releaseRefs        ReleaseAssetRef[] // indexed release<->asset (delete/GC safety)
  catalogReleaseRefs CatalogReleaseAssetRef[] // indexed catalogRelease<->asset (delete/GC safety)

  @@index([status, kind])
  @@index([deletedAt])
}

// Indexed "which retained release references this asset" — makes delete/GC an O(1) set query.
model ReleaseAssetRef {
  releaseId String
  release   Release @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  assetId   String
  asset     Asset   @relation(fields: [assetId], references: [id])

  @@id([releaseId, assetId])
  @@index([assetId])
}

// ===== BLOCK KINDS (registry classification; mirrors @signex/shared BlockKind) =====
// The relational ContentBlock table is gone (content now lives as JSON in Theme.draftSnapshot),
// but this enum is retained so @signex/db continues to export `BlockKind` for the shared
// (kind,key) registry parity assert until the importer/content code is fully on the themes model.
enum BlockKind {
  PAGE
  SETTINGS
  NAV
  SEO
}

// ===== FORM SUBMISSIONS (operational-only; NOT in snapshots) =====
enum SubmissionStatus {
  NEW
  READ
  ARCHIVED
}

model FormSubmission {
  id            String           @id @default(cuid())
  formKey       String // "quote" | "contact"
  payload       Json // zod-validated against the form's submit schema
  uploadAssetId String? // the form's "upload" field -> R2 Asset
  status        SubmissionStatus @default(NEW)
  flagged       Boolean          @default(false) // spam/duplicate marker — hidden from the inbox, bulk-clearable
  ip            String?
  userAgent     String?
  createdAt     DateTime         @default(now())

  @@index([formKey, status])
  @@index([createdAt])
  @@index([flagged, createdAt])
}

// ===== VERSIONING =====
enum ReleaseStatus {
  PUBLISHED
  ARCHIVED
}

// DRAFT removed (locked #4: working tables ARE the draft)

model Release {
  id                    String        @id @default(cuid())
  version               Int           @unique // assigned from a Postgres sequence
  status                ReleaseStatus @default(PUBLISHED)
  label                 String?
  note                  String?
  snapshot              Json // whole serialized site (ReleaseSnapshotSchema)
  checksum              String // sha256(canonical snapshot)
  schemaVersion         Int // stamped; web gates/migrates on this
  fromRevision          Int // WorkingState.revision at serialize time
  rolledBackFromVersion Int?
  themeId               String? // provenance: which theme this release was published from
  theme                 Theme?        @relation(fields: [themeId], references: [id], onDelete: SetNull)
  createdById           String
  createdBy             User          @relation("ReleaseCreatedBy", fields: [createdById], references: [id])
  publishedById         String?
  publishedBy           User?         @relation("ReleasePublishedBy", fields: [publishedById], references: [id])
  createdAt             DateTime      @default(now())
  publishedAt           DateTime?

  assetRefs        ReleaseAssetRef[]
  publishedPointer PublishedPointer?

  @@index([status])
  @@index([version])
  @@index([themeId])
}

// Singleton: site-wide infrastructure config that is INDEPENDENT of the published theme
// (so GA4 doesn't change when a different theme goes live). Edited on the admin Settings page,
// NOT in the theme editor. Mirrors the PublishedPointer singleton style (id = "singleton").
model SiteConfig {
  id        String   @id @default("singleton")
  ga4Id     String? // GA4 measurement id, e.g. G-XXXXXXXXXX; empty/null → no analytics injected
  updatedAt DateTime @updatedAt
}

// Singleton: which release is LIVE. Repoint = one-row update (atomic, cheap).
model PublishedPointer {
  id               String   @id @default("singleton")
  releaseId        String   @unique
  release          Release  @relation(fields: [releaseId], references: [id])
  publishedVersion Int
  publishedAt      DateTime @default(now())
  publishedById    String
}

// ===== THEMES (JSON-per-theme content model) =====
// A theme = a named full ReleaseSnapshot. The editor mutates draftSnapshot in place; publish freezes
// it into a Release. draftRevision is the per-theme optimistic lock (replaces the old WorkingState).
model Theme {
  id                    String    @id @default(cuid())
  name                  String    @unique
  draftSnapshot         Json // full ReleaseSnapshot (ReleaseSnapshotSchema) — the editable content
  liveSnapshot          Json? // snapshot frozen at THIS theme's last publish; null if never published
  draftRevision         Int       @default(0) // per-theme optimistic lock (bumped per save-draft)
  lastPublishedRevision Int       @default(0) // draftRevision at last publish; dirty iff != draftRevision
  lastPublishedChecksum String? // sha256(liveSnapshot) — gated-no-op + dirty signal
  createdById           String
  createdBy             User      @relation("ThemeCreatedBy", fields: [createdById], references: [id])
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  releases              Release[]

  @@index([updatedAt])
}

// ===== GLOBAL CATALOG DOMAIN (independent of themes/content) =====
// The product catalog is a single GLOBAL entity with its own draft → publish →
// rollback lifecycle, mirroring the content machinery (Theme + Release +
// PublishedPointer + ReleaseAssetRef) but scoped to the catalog and NOT tied to
// any theme. Catalog images are inline FrozenAssets inside the snapshot
// (self-contained); assetRefs exist only as GC pins.

// Singleton: the one editable global catalog. The admin catalog editor mutates
// draftSnapshot in place; publish freezes it into a CatalogRelease.
// draftRevision is the optimistic lock (replaces the theme draftRevision the
// catalog previously borrowed).
model CatalogDraft {
  id                    String   @id @default("singleton")
  draftSnapshot         Json // full CatalogSnapshot (CatalogSnapshotSchema) — the editable catalog
  liveSnapshot          Json? // snapshot frozen at the last catalog publish; null if never published
  draftRevision         Int      @default(0) // optimistic lock (bumped per catalog save-draft)
  lastPublishedRevision Int      @default(0) // draftRevision at last publish; dirty iff != draftRevision
  lastPublishedChecksum String? // sha256(liveSnapshot) — gated-no-op + dirty signal
  updatedById           String?
  updatedBy             User?    @relation("CatalogDraftUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  updatedAt             DateTime @updatedAt
}

// Immutable published catalog. Mirrors Release, catalog-scoped: no themeId, no
// blocks — just the frozen CatalogSnapshot. version is assigned from the
// dedicated catalog_release_version_seq Postgres sequence.
model CatalogRelease {
  id                    String        @id @default(cuid())
  version               Int           @unique // assigned from catalog_release_version_seq
  status                ReleaseStatus @default(PUBLISHED)
  label                 String?
  note                  String?
  snapshot              Json // frozen CatalogSnapshot (CatalogSnapshotSchema)
  checksum              String // sha256(canonical catalog snapshot)
  schemaVersion         Int // CATALOG_SCHEMA_VERSION; web gates/migrates on this
  fromRevision          Int // CatalogDraft.draftRevision at serialize time
  rolledBackFromVersion Int?
  createdById           String
  createdBy             User          @relation("CatalogReleaseCreatedBy", fields: [createdById], references: [id])
  publishedById         String?
  publishedBy           User?         @relation("CatalogReleasePublishedBy", fields: [publishedById], references: [id])
  createdAt             DateTime      @default(now())
  publishedAt           DateTime?

  assetRefs        CatalogReleaseAssetRef[]
  publishedPointer CatalogPublishedPointer?

  @@index([status])
  @@index([version])
}

// Singleton: which CatalogRelease is LIVE. Repoint = one-row update.
model CatalogPublishedPointer {
  id               String         @id @default("singleton")
  releaseId        String         @unique
  release          CatalogRelease @relation(fields: [releaseId], references: [id])
  publishedVersion Int
  publishedAt      DateTime       @default(now())
  publishedById    String
}

// Indexed "which retained catalog release references this asset" — makes
// delete/GC an O(1) set query for catalog-owned assets.
model CatalogReleaseAssetRef {
  releaseId String
  release   CatalogRelease @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  assetId   String
  asset     Asset          @relation(fields: [assetId], references: [id])

  @@id([releaseId, assetId])
  @@index([assetId])
}
