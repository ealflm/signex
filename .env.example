# ---------------------------------------------------------------------------
# Signex monorepo environment template.
# Copy to `.env` and adjust values: `cp .env.example .env`
# `.env` is gitignored; this `.env.example` is committed.
# ---------------------------------------------------------------------------

# Postgres (consumed by the `postgres` Compose service)
POSTGRES_USER=signex
POSTGRES_PASSWORD=signex
POSTGRES_DB=signex
# Host port published for the postgres container (container listens on 5432 inside).
POSTGRES_PORT=3059

# Prisma / DB connection.
# Local dev uses host `localhost`. INSIDE Docker Compose change the host to
# `postgres` (the service name): postgresql://signex:signex@postgres:5432/signex?schema=public
DATABASE_URL=postgresql://signex:signex@localhost:3059/signex?schema=public

# Service ports
API_PORT=3060
WEB_PORT=3062
ADMIN_PORT=3061

# CORS + OriginGuard allow-list (comma-separated browser origins allowed to call the api).
# Used by both app.enableCors() and the server-side OriginGuard.
# In production, replace with your real public web/admin URLs.
AUTH_ALLOWED_ORIGINS=http://localhost:3062,http://localhost:3061

# API URLs
# API_URL is the server-side base used inside the Compose network (service name `api`).
API_URL=http://api:3060
# NEXT_PUBLIC_API_URL is the client-side (browser) base; exposed to the frontends.
NEXT_PUBLIC_API_URL=http://localhost:3060

# ---------------------------------------------------------------------------
# Seed / bootstrap (consumed by `npm run auth:seed -w @signex/api`).
# Deploy order (spec §8):
#   1) npm run migrate:deploy -w @signex/db   # create tables + release_version_seq
#   2) npm run auth:seed -w @signex/api        # idempotent fixed SYSTEM/ADMIN user
#   3) run the importer (build step 7)         # mints Release v1 with the system actor
# (`npm run db:deploy -w @signex/api` runs steps 1+2 together.)
# auth:seed is IDEMPOTENT — safe to re-run on every deploy.
# ---------------------------------------------------------------------------
SEED_ADMIN_EMAIL=admin@signex.local
SEED_ADMIN_NAME=System Admin
# MUST be >= 12 chars. CHANGE THIS before any real deploy; rotate after first login.
SEED_ADMIN_PASSWORD=change-me-please-now

# ---------------------------------------------------------------------------
# R2 media storage (Cloudflare R2 / S3-compatible).
# Used by AssetsService to store + serve media via presigned URLs.
# ---------------------------------------------------------------------------
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=YOUR_R2_ACCESS_KEY_ID
R2_SECRET_ACCESS_KEY=YOUR_R2_SECRET_ACCESS_KEY
R2_BUCKET=signex-media
# Optional: R2 region (default: 'auto')
R2_REGION=auto
# Optional: presigned URL TTL in seconds (default: 300)
R2_PRESIGN_TTL=300
# Public CDN base (no trailing slash). Used by release serializer to resolve media URLs.
# Must NOT be an r2.dev host (the publish gate rejects those). Use a custom domain in production.
# For local acceptance a non-r2.dev placeholder satisfies the gate.
MEDIA_PUBLIC_BASE=http://localhost:9000/signex-media

# ---------------------------------------------------------------------------
# Admin shell (apps/admin) — CSRF + control-plane secrets.
# ADMIN_ORIGIN: the admin's own public origin (the only origin allowed to POST to its route handlers).
ADMIN_ORIGIN=http://localhost:3061
# ALLOWED_ORIGINS: comma-separated CSRF allowlist (admin + web browser origins).
# Used by admin route handlers (ALLOWED_ORIGINS) and api OriginGuard (AUTH_ALLOWED_ORIGINS).
ALLOWED_ORIGINS=http://localhost:3061,http://localhost:3062
# Shared secret the api presents to apps/web /api/revalidate (x-revalidate-secret header).
# Must match REVALIDATE_SECRET in both the api and web services.
REVALIDATE_SECRET=dev-revalidate-secret-change-me
# Shared secret for POST /api/preview/snapshot (draft preview entry).
# Must match PREVIEW_SECRET in both the api and admin services.
PREVIEW_SECRET=dev-preview-secret-change-me
# Public web origin the admin links to for "view live" / preview.
NEXT_PUBLIC_WEB_URL=http://localhost:3062
# URL the api's RevalidationService POSTs to trigger Next.js on-demand ISR on the web service.
# Inside the Compose network use the service name; outside use the public web URL.
WEB_REVALIDATE_URL=http://web:3062/api/revalidate
